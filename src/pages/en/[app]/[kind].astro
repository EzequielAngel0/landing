---
import { render } from 'astro:content';
import Legal from '../../../layouts/Legal.astro';
import { getLegal } from '../../../lib/legal';
import { kindSlugEn } from '../../../data/legal-meta';

// English legal routes with localized slugs: /en/<app>/<slug>/ (privacy, terms,
// data-deletion). The Spanish pair keeps the collection kind: /<app>/<kind>/.
export async function getStaticPaths() {
  const entries = await getLegal('en');
  return entries.map((entry) => ({
    params: { app: entry.data.app, kind: kindSlugEn[entry.data.kind] ?? entry.data.kind },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const updated = entry.data.updatedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const alternateHref = `/${entry.data.app}/${entry.data.kind}/`;
---

<Legal title={entry.data.title} updatedAt={updated} locale="en" alternateHref={alternateHref}>
  <Content />
</Legal>
