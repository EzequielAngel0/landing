---
import Base from './Base.astro';

interface Props {
  title: string;
  updatedAt: string;
  locale?: 'es' | 'en';
  // URL de la version en el otro idioma; el boton vive en el header (Base).
  alternateHref?: string;
}

const { title, updatedAt, locale = 'es', alternateHref } = Astro.props;

const t =
  locale === 'en'
    ? { back: 'Back to home', backHref: '/en/', doc: 'Legal document', updated: 'Updated on' }
    : { back: 'Volver al inicio', backHref: '/', doc: 'Documento legal', updated: 'Actualizado el' };
---

<Base title={`${title} - angelezequiel.dev`} lang={locale} alternateHref={alternateHref}>
  <div class="mx-auto max-w-[46rem] py-16">
    <p class="mb-8">
      <a href={t.backHref} class="font-mono text-label text-ink-soft underline hover:text-accent">
        {t.back}
      </a>
    </p>
    <article class="space-y-6">
      <header class="space-y-2 border-b border-line pb-6">
        <p class="font-mono text-label uppercase tracking-[0.2em] text-ink-soft">{t.doc}</p>
        <h1 class="text-3xl font-semibold text-ink">{title}</h1>
        <p class="font-mono text-label text-ink-soft">{t.updated} {updatedAt}</p>
      </header>
      <div class="prose-legal">
        <slot />
      </div>
    </article>
  </div>
</Base>
