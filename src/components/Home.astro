---
import Base from '../layouts/Base.astro';
import { links } from '../data/links';
import { getLegal } from '../lib/legal';
import {
  appLabels,
  appLabelsEn,
  appOrder,
  kindLabels,
  kindLabelsEn,
  kindSlugEn,
  kindOrder,
} from '../data/legal-meta';

interface Props {
  locale: 'es' | 'en';
}

const { locale } = Astro.props;
const isEn = locale === 'en';

const t = isEn
  ? {
      tag: 'Entry point',
      intro:
        'Developer. This is my hub: from here you can reach my portfolio, my social profiles and the legal pages of my apps.',
      status: 'Static site, up and running',
      dirAria: 'Link directory',
      legalTag: 'Legal documents',
      legalIntro:
        'Privacy and terms pages for my applications and for this site, with a public, stable URL for store validation.',
      altPill: 'es',
      altPillAria: 'Spanish version',
    }
  : {
      tag: 'Punto de entrada',
      intro:
        'Desarrollador. Este es mi hub: desde aquí llegas a mi portfolio, mis redes y las páginas legales de mis apps.',
      status: 'Sitio estático, operativo',
      dirAria: 'Directorio de enlaces',
      legalTag: 'Documentos legales',
      legalIntro:
        'Páginas de privacidad y términos de mis aplicaciones y de este sitio, con URL pública y estable para la validación de las tiendas.',
      altPill: 'en',
      altPillAria: 'English version',
    };

const legal = await getLegal(locale);
const apps = [...new Set(legal.map((e) => e.data.app))].sort(
  (a, b) => (appOrder[a] ?? 9) - (appOrder[b] ?? 9),
);
const legalByApp = apps.map((app) => ({
  app,
  label: isEn ? (appLabelsEn[app] ?? app) : (appLabels[app] ?? app),
  docs: legal
    .filter((e) => e.data.app === app)
    .sort((a, b) => (kindOrder[a.data.kind] ?? 9) - (kindOrder[b.data.kind] ?? 9)),
}));

const docHref = (app: string, kind: string) =>
  isEn ? `/en/${app}/${kindSlugEn[kind] ?? kind}/` : `/${app}/${kind}/`;
const docAltHref = (app: string, kind: string) =>
  isEn ? `/${app}/${kind}/` : `/en/${app}/${kindSlugEn[kind] ?? kind}/`;
const docLabel = (kind: string) => (isEn ? (kindLabelsEn[kind] ?? kind) : (kindLabels[kind] ?? kind));
---

<Base
  title="Angel Ezequiel Barbosa Lomeli"
  lang={locale}
  alternateHref={isEn ? '/' : '/en/'}
>
  <div class="mx-auto max-w-[46rem]">
    <section class="flex min-h-[calc(100svh-3.5rem)] flex-col justify-center gap-10 py-16">
      <header class="space-y-4">
        <p class="font-mono text-label uppercase tracking-[0.2em] text-ink-soft">
          <span class="text-status">//</span> {t.tag}
        </p>
        <h1 class="hero-name text-ink">Angel Ezequiel<br />Barbosa Lomeli</h1>
        <p class="max-w-prose text-lg leading-relaxed text-ink-soft">{t.intro}</p>
        <p class="inline-flex items-center gap-2 font-mono text-label text-ink-soft">
          <span class="inline-block size-2 rounded-full bg-status"></span>
          {t.status}
        </p>
      </header>

      <nav id="directorio" aria-label={t.dirAria} class="rounded-xs border border-line">
        <ul class="divide-y divide-line">
          {
            links.map((l, i) => (
              <li>
                <a
                  href={l.href}
                  class="group flex items-center gap-4 px-5 py-4 transition-colors"
                  {...(l.kind !== 'mailto' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <span class="font-mono text-label tabular-nums text-ink-soft">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="flex flex-1 flex-col">
                    <span class="text-lg text-ink transition-colors group-hover:text-accent">
                      {isEn ? (l.labelEn ?? l.label) : l.label}
                    </span>
                    {(isEn ? (l.noteEn ?? l.note) : l.note) && (
                      <span class="text-sm text-ink-soft">
                        {isEn ? (l.noteEn ?? l.note) : l.note}
                      </span>
                    )}
                  </span>
                  <svg
                    class="size-5 shrink-0 text-ink-soft transition-transform group-hover:translate-x-1 group-hover:text-accent"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </section>

    <section id="legales" class="border-t border-line py-14">
      <p class="font-mono text-label uppercase tracking-[0.2em] text-ink-soft">
        <span class="text-status">//</span> {t.legalTag}
      </p>
      <p class="mt-3 max-w-prose text-ink-soft">{t.legalIntro}</p>

      <div class="mt-8 space-y-8">
        {
          legalByApp.map((group) => (
            <div>
              <h2 class="text-lg font-semibold text-ink">{group.label}</h2>
              <ul class="mt-3 divide-y divide-line rounded-xs border border-line">
                {group.docs.map((doc) => (
                  <li class="flex items-center">
                    <a
                      href={docHref(doc.data.app, doc.data.kind)}
                      class="group flex flex-1 flex-wrap items-center justify-between gap-x-4 gap-y-1 px-5 py-3.5 transition-colors"
                    >
                      <span class="text-ink transition-colors group-hover:text-accent">
                        {docLabel(doc.data.kind)}
                      </span>
                      <span class="font-mono text-label text-ink-soft">
                        {docHref(doc.data.app, doc.data.kind)}
                      </span>
                    </a>
                    <a
                      href={docAltHref(doc.data.app, doc.data.kind)}
                      hreflang={isEn ? 'es' : 'en'}
                      lang={isEn ? 'es' : 'en'}
                      aria-label={`${docLabel(doc.data.kind)} (${t.altPillAria})`}
                      class="mr-4 rounded-xs border border-line px-2 py-0.5 font-mono text-label uppercase text-ink-soft transition-colors hover:text-accent"
                    >
                      {t.altPill}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Base>
